generator client {
  provider      = "prisma-client-js"
  // binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                  String                @id @default(uuid())
  nome                String
  email               String                @unique
  senha               String
  perfil              PerfilUsuario         @default(USUARIO)
  criadoEm            DateTime              @default(now())
  perfisJogador       Jogador[]
  torneiosOrganizados OrganizadorTorneios[]
}

model Torneio {
  id            String                @id @default(uuid())
  nome          String
  descricao     String?
  local         String?
  dataInicio    DateTime?
  dataFim       DateTime?
  status        StatusTorneio         @default(RASCUNHO)
  visibilidade  VisibilidadeTorneio   @default(PRIVADO)
  bannerUrl     String?
  logoUrl       String?
  tokenConvite  String?
  formato       FormatoTorneio        @default(MATA_MATA)
  criadoEm      DateTime              @default(now())
  organizadores OrganizadorTorneios[]
  partidas      Partida[]
  regras        RegrasTorneio?
  times         Time[]
  fases         FaseTorneio[]
}

model RegrasTorneio {
  id                     String  @id @default(uuid())
  setsParaVencer         Int     @default(2)
  pontosPorSet           Int     @default(25)
  pontosTieBreak         Int     @default(15)
  vantagemDoisPontos     Boolean @default(true)
  limiteJogadoresPorTime Int?
  torneioId              String  @unique
  torneio                Torneio @relation(fields: [torneioId], references: [id], onDelete: Cascade)
}

model OrganizadorTorneios {
  id        String  @id @default(uuid())
  torneioId String
  usuarioId String
  torneio   Torneio @relation(fields: [torneioId], references: [id], onDelete: Cascade)
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([torneioId, usuarioId])
}

model FaseTorneio {
  id        String   @id @default(uuid())
  torneioId String
  tipo      FormatoTorneio
  ordem     Int
  nome      String?
  criadoEm  DateTime @default(now())

  torneio           Torneio            @relation(fields: [torneioId], references: [id], onDelete: Cascade)
  configuracaoRacha ConfiguracaoRacha?
  poolJogadores     PoolJogadorRacha[]
  filaRacha         FilaRachaEstado?
  times             Time[]

  @@unique([torneioId, ordem])
}

enum ModoFormacaoTimes {
  MANUAL
  POOL_SORTEIO
}

enum CriterioSorteio {
  ALEATORIO
  NOTA
}

enum ModoGeracaoPartidas {
  AUTOMATICO
  MANUAL
}

model ConfiguracaoRacha {
  id     String @id @default(uuid())
  faseId String @unique
  fase   FaseTorneio @relation(fields: [faseId], references: [id], onDelete: Cascade)

  modoFormacaoTimes        ModoFormacaoTimes   @default(MANUAL)
  criterioSorteio          CriterioSorteio     @default(ALEATORIO)
  modoGeracaoPartidas      ModoGeracaoPartidas @default(MANUAL)
  jogadoresPorTime         Int                 @default(4)
  vitoriasSeguidasParaSair Int                 @default(2)

  atualizadoEm DateTime @updatedAt
}

model PoolJogadorRacha {
  id        String   @id @default(uuid())
  faseId    String
  jogadorId String
  alocado   Boolean  @default(false)
  criadoEm  DateTime @default(now())

  fase    FaseTorneio @relation(fields: [faseId], references: [id], onDelete: Cascade)
  jogador Jogador     @relation(fields: [jogadorId], references: [id], onDelete: Cascade)

  @@unique([faseId, jogadorId])
}

model FilaRachaEstado {
  id     String @id @default(uuid())
  faseId String @unique
  fase   FaseTorneio @relation(fields: [faseId], references: [id], onDelete: Cascade)

  timeDefensorId   String?
  vitoriasSeguidas Int      @default(0)
  timesAguardando  Json     @default("[]")
  partidaAtualId   String?
  atualizadoEm     DateTime @updatedAt
}

model Time {
  id                  String           @id @default(uuid())
  nome                String
  logoUrl             String?
  tokenConvite        String?          @unique
  quantidadeJogadores Int              @default(0)
  torneioId           String
  faseId              String?
  corPrimaria         String?
  corSecundaria       String?
  email               String?
  facebook            String?
  instagram           String?
  site                String?
  telefone            String?
  whatsapp            String?
  jogadores           Jogador[]
  jogadoresNaPartida  JogadorPartida[]
  partidasComoCasa    Partida[]        @relation("PartidaCasa")
  partidasComoVisita  Partida[]        @relation("PartidaVisitante")
  torneio             Torneio          @relation(fields: [torneioId], references: [id], onDelete: Cascade)
  fase                FaseTorneio?     @relation(fields: [faseId], references: [id], onDelete: SetNull)
}

model Jogador {
  id               String             @id @default(uuid())
  nome             String
  numeroCamisa     Int?
  posicao          String?
  fotoUrl          String?
  entrouPorLink    Boolean            @default(false)
  titular          Boolean            @default(false)
  indicePosicao    Int?
  notaHabilidade   Float?
  criadoEm         DateTime           @default(now())
  timeId           String?
  usuarioId        String?
  eventosPartida   EventoPartida[]
  time             Time?              @relation(fields: [timeId], references: [id], onDelete: SetNull)
  usuario          Usuario?           @relation(fields: [usuarioId], references: [id])
  aparicoesPartida JogadorPartida[]
  aparicoesPool    PoolJogadorRacha[]
}

model Partida {
  id                 String                 @id @default(uuid())
  status             StatusPartida          @default(AGENDADA)
  agendadoPara       DateTime?
  local              String?
  setsCasa           Int                    @default(0)
  setsVisitante      Int                    @default(0)
  setAtualCasa       Int                    @default(0)
  setAtualVisitante  Int                    @default(0)
  torneioId          String
  timeCasaId         String
  timeVisitanteId    String
  eventosPartida     EventoPartida[]
  jogadoresNaPartida JogadorPartida[]
  escalacoes         EscalacaoSet[]
  substituicoes      SubstituicaoPartida[]
  timeCasa           Time                   @relation("PartidaCasa", fields: [timeCasaId], references: [id], onDelete: Cascade)
  timeVisitante      Time                   @relation("PartidaVisitante", fields: [timeVisitanteId], references: [id], onDelete: Cascade)
  torneio            Torneio                @relation(fields: [torneioId], references: [id], onDelete: Cascade)
}

model EscalacaoSet {
  id                 String   @id @default(uuid())
  partidaId          String
  indiceSet          Int
  timeId             String
  titulares          Json
  banco              Json
  indicePosicaoSaque Int      @default(1)
  sacaPrimeiro       Boolean  @default(false)
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt
  partida            Partida  @relation(fields: [partidaId], references: [id], onDelete: Cascade)

  @@unique([partidaId, indiceSet, timeId])
}

model SubstituicaoPartida {
  id                    String   @id @default(uuid())
  partidaId             String
  indiceSet             Int
  timeId                String
  idJogadorSaindo       String
  nomeJogadorSaindo     String
  numeroJogadorSaindo   Int?
  idJogadorEntrando     String
  nomeJogadorEntrando   String
  numeroJogadorEntrando Int?
  indicePosicao         Int
  placarCasa            Int
  placarVisitante       Int
  criadoEm              DateTime @default(now())
  partida               Partida  @relation(fields: [partidaId], references: [id], onDelete: Cascade)
}

model JogadorPartida {
  id           String  @id @default(uuid())
  titular      Boolean @default(false)
  numeroCamisa Int?
  posicao      String?
  partidaId    String
  jogadorId    String
  timeId       String
  jogador      Jogador @relation(fields: [jogadorId], references: [id], onDelete: Cascade)
  partida      Partida @relation(fields: [partidaId], references: [id], onDelete: Cascade)
  time         Time    @relation(fields: [timeId], references: [id], onDelete: Cascade)

  @@unique([jogadorId, partidaId])
}

model EventoPartida {
  id                    String      @id @default(uuid())
  indiceSet             Int
  lado                  LadoPonto
  tipo                  TipoPonto
  tipoErro              TipoErro?
  tipoCartao            TipoCartao?
  placarCasa            Int
  placarVisitante       Int
  horario               DateTime    @default(now())
  anulado               Boolean     @default(false)
  partidaId             String
  jogadorId             String?
  jogadorNome           String?
  quadraCasaAntes       Json?
  quadraVisitanteAntes  Json?
  quadraCasaDepois      Json?
  quadraVisitanteDepois Json?
  sacadorAntes          LadoPonto?
  sacadorDepois         LadoPonto?
  jogador               Jogador?    @relation(fields: [jogadorId], references: [id])
  partida               Partida     @relation(fields: [partidaId], references: [id], onDelete: Cascade)
}

enum PerfilUsuario {
  ADMIN
  GERENTE
  USUARIO
}

enum StatusTorneio {
  RASCUNHO
  ABERTO
  EM_ANDAMENTO
  FINALIZADO
}

enum VisibilidadeTorneio {
  PUBLICO
  SOMENTE_PARTICIPANTES
  PRIVADO
}

enum FormatoTorneio {
  RACHA
  MATA_MATA
  PONTOS_CORRIDOS
}

enum StatusPartida {
  AGENDADA
  AQUECIMENTO
  AO_VIVO
  FINALIZADA
}

enum TipoPonto {
  SAQUE
  ATAQUE
  BLOQUEIO
  ERRO_ADVERSARIO
  CARTAO_ADVERSARIO
}

enum TipoErro {
  ERRO_SAQUE
  ERRO_ATAQUE
  TOQUE_REDE
  INVASAO
  BOLA_FORA
  DOIS_TOQUES
  QUATRO_TOQUES
  CONDUCAO
  ERRO_ROTACAO
}

enum LadoPonto {
  CASA
  VISITANTE
}

enum TipoCartao {
  AMARELO
  VERMELHO
}
